# Copy to .env and fill in. Keep .env out of git.

# --- providers (you only need keys for the ones you actually use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- defaults ---
SLEUTH_DEFAULT_PROVIDER=openai
SLEUTH_DEFAULT_MODEL=gpt-5.5

# --- telegram (optional, for finished-job pings) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- discord (optional, alternative or addition to telegram) ---
# Server -> channel -> Edit channel -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=

# --- google drive sync (optional) ---
# Recommended: create a tiny OAuth client once in Google Cloud Console
# (application type: "TVs and Limited Input devices"), then drop the two
# values here. After that, `sleuth drive login` is all anyone has to run.
SLEUTH_GOOGLE_CLIENT_ID=
SLEUTH_GOOGLE_CLIENT_SECRET=

# Optional: pin a folder ID for synced Docs. `sleuth drive login` will set
# this for you (auto-creating a "Sleuth" folder in My Drive).
GDRIVE_FOLDER_ID=

# Legacy: per-user path to a downloaded client_secret*.json. Still works
# if set, but prefer the env vars above.
GDRIVE_CLIENT_SECRET_PATH=

# --- paths (optional overrides) ---
# SLEUTH_DATA_DIR=/home/pi/sleuth/data
# SLEUTH_OUTPUT_DIR=/home/pi/sleuth/outputs
